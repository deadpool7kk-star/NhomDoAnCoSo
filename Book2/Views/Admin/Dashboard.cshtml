@model Book2.ViewModels.AdminDashboardVM

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
}

<!-- Thống kê chung -->
<div class="row g-4 mb-4">
    <!-- Hàng 1 -->
    <div class="col-md-3">
        <a asp-controller="AdminDonHang" asp-action="Index" class="text-decoration-none h-100">
            <div class="card card-box border-0 shadow-sm h-100 stat-card" style="border-left: 5px solid #0d6efd !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted fw-semibold mb-1">Tổng đơn hàng</div>
                            <h3 class="fw-bold text-primary mb-0">@Model.TongDonHang</h3>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle text-primary">
                            <i class="bi bi-cart-check fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="AdminDonHang" asp-action="Index" asp-route-trangThai="Hoàn thành" class="text-decoration-none h-100">
            <div class="card card-box border-0 shadow-sm h-100 stat-card" style="border-left: 5px solid #198754 !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted fw-semibold mb-1">Tổng doanh thu</div>
                            <h3 class="fw-bold text-success mb-0">@Model.TongDoanhThu.ToString("N0")₫</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded-circle text-success">
                            <i class="bi bi-currency-dollar fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="AdminSach" asp-action="Index" class="text-decoration-none h-100">
            <div class="card card-box border-0 shadow-sm h-100 stat-card" style="border-left: 5px solid #ffc107 !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted fw-semibold mb-1">Sách đang bán</div>
                            <h3 class="fw-bold text-warning mb-0">@Model.TongSach</h3>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded-circle text-warning">
                            <i class="bi bi-book fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="UserManagement" asp-action="Index" class="text-decoration-none h-100">
            <div class="card card-box border-0 shadow-sm h-100 stat-card" style="border-left: 5px solid #0dcaf0 !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted fw-semibold mb-1">Khách hàng</div>
                            <h3 class="fw-bold text-info mb-0">@Model.TongKhachHang</h3>
                        </div>
                        <div class="bg-info bg-opacity-10 p-3 rounded-circle text-info">
                            <i class="bi bi-people fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <!-- Hàng 2 -->
    <div class="col-md-3">
        <a asp-controller="AdminDonHang" asp-action="Index" asp-route-trangThai="Chờ xác nhận" class="text-decoration-none h-100">
            <div class="card card-box border-0 shadow-sm h-100 stat-card" style="border-left: 5px solid #6c757d !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted fw-semibold mb-1">Chờ xác nhận</div>
                            <h3 class="fw-bold text-secondary mb-0">@Model.DonChoXacNhan</h3>
                        </div>
                        <div class="bg-secondary bg-opacity-10 p-3 rounded-circle text-secondary">
                            <i class="bi bi-clock-history fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="AdminDonHang" asp-action="Index" asp-route-trangThai="Đang giao" class="text-decoration-none h-100">
            <div class="card card-box border-0 shadow-sm h-100 stat-card" style="border-left: 5px solid #fd7e14 !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted fw-semibold mb-1">Đang giao</div>
                            <h3 class="fw-bold mb-0" style="color: #fd7e14;">@Model.DonDangGiao</h3>
                        </div>
                        <div class="p-3 rounded-circle" style="background-color: rgba(253, 126, 20, 0.1); color: #fd7e14;">
                            <i class="bi bi-truck fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="AdminDonHang" asp-action="Index" asp-route-trangThai="Hoàn thành" class="text-decoration-none h-100">
            <div class="card card-box border-0 shadow-sm h-100 stat-card" style="border-left: 5px solid #20c997 !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted fw-semibold mb-1">Hoàn thành</div>
                            <h3 class="fw-bold text-teal mb-0" style="color: #20c997;">@Model.DonHoanThanh</h3>
                        </div>
                        <div class="p-3 rounded-circle" style="background-color: rgba(32, 201, 151, 0.1); color: #20c997;">
                            <i class="bi bi-check-circle fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="AdminDonHang" asp-action="Index" asp-route-trangThai="Đã hủy" class="text-decoration-none h-100">
            <div class="card card-box border-0 shadow-sm h-100 stat-card" style="border-left: 5px solid #dc3545 !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted fw-semibold mb-1">Đã hủy</div>
                            <h3 class="fw-bold text-danger mb-0">@Model.DonDaHuy</h3>
                        </div>
                        <div class="bg-danger bg-opacity-10 p-3 rounded-circle text-danger">
                            <i class="bi bi-x-circle fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

<style>
    .stat-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        cursor: pointer;
    }
    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>

<!-- Biểu đồ doanh thu -->
<div class="card card-box border-0 shadow-sm mt-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
        <h5 class="fw-bold mb-0"><i class="bi bi-graph-up-arrow text-success me-2"></i>Biểu đồ doanh thu</h5>
        <select id="chartPeriod" class="form-select w-auto rounded-pill shadow-sm">
            <option value="day">30 ngày gần nhất</option>
            <option value="month" selected>Các tháng trong năm</option>
            <option value="year">5 năm gần nhất</option>
        </select>
    </div>
    <div class="card-body">
        <div style="height: 400px;">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const ctx = document.getElementById('revenueChart').getContext('2d');
            let revenueChart;

            function loadChartData(period) {
                fetch(`/Admin/GetChartData?period=${period}`)
                    .then(response => response.json())
                    .then(data => {
                        if (revenueChart) {
                            revenueChart.destroy();
                        }

                        // Gradient background cho biểu đồ line
                        let gradient = ctx.createLinearGradient(0, 0, 0, 400);
                        gradient.addColorStop(0, 'rgba(25, 135, 84, 0.5)'); // success color
                        gradient.addColorStop(1, 'rgba(25, 135, 84, 0.0)');

                        revenueChart = new Chart(ctx, {
                            type: period === 'day' ? 'line' : 'bar',
                            data: {
                                labels: data.labels,
                                datasets: [{
                                    label: 'Doanh thu (VNĐ)',
                                    data: data.values,
                                    backgroundColor: period === 'day' ? gradient : 'rgba(25, 135, 84, 0.8)',
                                    borderColor: '#198754',
                                    borderWidth: 2,
                                    pointBackgroundColor: '#fff',
                                    pointBorderColor: '#198754',
                                    pointBorderWidth: 2,
                                    pointRadius: 4,
                                    pointHoverRadius: 6,
                                    fill: period === 'day' ? true : false,
                                    borderRadius: period === 'day' ? 0 : 4 // bo góc cho bar chart
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: {
                                        display: false
                                    },
                                    tooltip: {
                                        callbacks: {
                                            label: function(context) {
                                                let label = context.dataset.label || '';
                                                if (label) {
                                                    label += ': ';
                                                }
                                                if (context.parsed.y !== null) {
                                                    label += new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(context.parsed.y);
                                                }
                                                return label;
                                            }
                                        }
                                    }
                                },
                                scales: {
                                    y: {
                                        beginAtZero: true,
                                        ticks: {
                                            callback: function(value, index, values) {
                                                return new Intl.NumberFormat('vi-VN', { notation: "compact", compactDisplay: "short" }).format(value);
                                            }
                                        },
                                        grid: {
                                            borderDash: [5, 5],
                                            color: '#e9ecef'
                                        }
                                    },
                                    x: {
                                        grid: {
                                            display: false
                                        }
                                    }
                                }
                            }
                        });
                    })
                    .catch(error => console.error('Error fetching chart data:', error));
            }

            // Tải dữ liệu ban đầu
            loadChartData('month');

            // Xử lý sự kiện khi thay đổi kỳ xem
            document.getElementById('chartPeriod').addEventListener('change', function (e) {
                loadChartData(e.target.value);
            });
        });
    </script>
}