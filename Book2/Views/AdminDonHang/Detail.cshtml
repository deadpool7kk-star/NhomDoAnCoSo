@model IEnumerable<Book2.Models.ChiTietDonHang>

@{
    if (User.IsInRole("Admin"))
    {
        Layout = "_AdminLayout";
    }
    else if (User.IsInRole("Staff"))
    {
        Layout = "_AdminLayout";
    }
    else
    {
        Layout = "_ShipperLayout";
    }

    ViewData["Title"] = "Chi tiết đơn hàng";
    var donHang = ViewBag.DonHang as Book2.Models.DonHang;
    var trangThaiList = ViewBag.TrangThaiList as List<string> ?? new();
}

@if (donHang != null)
{
    <div class="card card-box mb-4">
        <div class="card-body">
            <h3 class="fw-bold mb-3">Đơn hàng #@donHang.Id</h3>

            <div class="row">
                <div class="col-md-6">
                    <p><strong>Người nhận:</strong> @donHang.TenNguoiNhan</p>
                    <p><strong>SĐT:</strong> @donHang.SoDienThoai</p>
                    <p><strong>Địa chỉ:</strong> @donHang.DiaChiNhanHang</p>
                </div>

                <div class="col-md-6 text-end">
                    <p><strong>Ngày đặt:</strong> @donHang.NgayDat.ToString("dd/MM/yyyy HH:mm")</p>
                    <p><strong>Tạm tính:</strong> @((donHang.TongTien + donHang.SoTienGiam).ToString("N0"))₫</p>
                    @if (donHang.SoTienGiam > 0)
                    {
                        <p class="text-danger"><strong>Giảm giá (@donHang.CouponCode):</strong> -@donHang.SoTienGiam.ToString("N0")₫</p>
                    }
                    <p class="text-success h5"><strong>Tổng thanh toán:</strong> @donHang.TongTien.ToString("N0")₫</p>
                    <p>
                        <strong>Trạng thái hiện tại:</strong>
                        @if (donHang.TrangThai == "Chờ xác nhận")
                        {
                            <span class="badge bg-secondary">@donHang.TrangThai</span>
                        }
                        else if (donHang.TrangThai == "Đang giao")
                        {
                            <span class="badge bg-primary">@donHang.TrangThai</span>
                        }
                        else if (donHang.TrangThai == "Hoàn thành")
                        {
                            <span class="badge bg-success">@donHang.TrangThai</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">@donHang.TrangThai</span>
                        }
                    </p>
                </div>
            </div>

            <div class="d-flex flex-column mt-3 border-top pt-3">
                @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                {
                    <div class="mb-4">
                        <form asp-action="AssignShipper" method="post" class="row g-3 align-items-end">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@donHang.Id" />
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-uppercase text-muted">Giao cho Shipper</label>
                                <select name="shipperId" class="form-select border-success shadow-sm">
                                    <option value="">-- Chọn Shipper --</option>
                                    @foreach (var shipper in ViewBag.ShipperList as IEnumerable<Book2.Models.ApplicationUser>)
                                    {
                                        if (shipper.Id == donHang.ShipperId)
                                        {
                                            <option value="@shipper.Id" selected>@shipper.HoTen (@shipper.Email)</option>
                                        }
                                        else
                                        {
                                            <option value="@shipper.Id">@shipper.HoTen (@shipper.Email)</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="btn btn-primary w-100 shadow-sm"><i class="bi bi-person-check-fill me-1"></i> Gán Shipper</button>
                            </div>
                            @if (!string.IsNullOrEmpty(donHang.ShipperId))
                            {
                                <div class="col-md-5">
                                    <div class="alert alert-info py-2 px-3 mb-0 d-flex align-items-center shadow-sm border-0">
                                        <i class="bi bi-truck me-2 h5 mb-0"></i>
                                        <span>Shipper hiện tại: <strong>@donHang.Shipper?.HoTen</strong></span>
                                    </div>
                                </div>
                            }
                        </form>
                    </div>
                }
                else if (User.IsInRole("Shipper") && !string.IsNullOrEmpty(donHang.ShipperId))
                {
                    <div class="alert alert-success border-0 shadow-sm mb-4">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Đơn hàng này đã được gán cho bạn.
                    </div>
                }

                <div class="d-flex justify-content-between align-items-center">
                    @if (donHang.TrangThai != "Hoàn thành" && donHang.TrangThai != "Đã hủy")
                    {
                        <form asp-action="UpdateStatus" method="post" class="flex-grow-1 me-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@donHang.Id" />

                            <div class="row g-3 align-items-end">
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold text-uppercase text-muted">Cập nhật trạng thái</label>
                                    <select name="trangThai" class="form-select border-success shadow-sm">
                                        @foreach (var item in trangThaiList)
                                        {
                                            if (item == donHang.TrangThai)
                                            {
                                                <option value="@item" selected>@item</option>
                                            }
                                            else
                                            {
                                                <option value="@item">@item</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="col-md-3">
                                    <button type="submit" class="btn btn-success w-100 shadow-sm"><i class="bi bi-save me-1"></i> Lưu trạng thái</button>
                                </div>
                            </div>
                        </form>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                    {
                        <a asp-action="InHoaDon" asp-route-id="@donHang.Id" class="btn btn-outline-dark px-4 shadow-sm" target="_blank">
                            <i class="bi bi-printer me-1"></i> In Hóa Đơn PDF
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
}

<div class="card card-box">
    <div class="card-body">
        <h4 class="fw-bold mb-3">Sản phẩm trong đơn</h4>

        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Tên sách</th>
                    <th>Đơn giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@(item.Sach?.TenSach ?? "Không còn dữ liệu")</td>
                        <td>@item.DonGia.ToString("N0") VNĐ</td>
                        <td>@item.SoLuong</td>
                        <td>@((item.DonGia * item.SoLuong).ToString("N0")) VNĐ</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>