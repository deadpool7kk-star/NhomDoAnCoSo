@model Book2.Models.Sach

@{
    ViewData["Title"] = "Chi tiết sách";
    var sachLienQuan = ViewBag.SachLienQuan as List<Book2.Models.Sach>;
}

<div class="container py-4">
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary mb-4">
        ← Quay lại trang chủ
    </a>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row g-4">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <img src="@(string.IsNullOrEmpty(Model.HinhAnh) ? "/images/no-image.png" : Model.HinhAnh)"
                     class="img-fluid rounded"
                     style="width: 100%; max-height: 550px; object-fit: cover;"
                     alt="@Model.TenSach" />
            </div>
        </div>

        <div class="col-md-7">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <span class="badge bg-success mb-2">
                        @(Model.TheLoai?.TenTheLoai ?? "Chưa có thể loại")
                    </span>

                    <h2 class="fw-bold mb-3">@Model.TenSach</h2>

                    <p class="mb-2">
                        <strong>Tác giả:</strong> @Model.TacGia
                    </p>

                    <p class="mb-2">
                        <strong>Số lượng còn:</strong>
                        @if (Model.SoLuong > 0)
                        {
                            <span class="text-success fw-semibold">@Model.SoLuong</span>
                        }
                        else
                        {
                            <span class="text-danger fw-semibold">Hết hàng</span>
                        }
                    </p>

                    <h3 class="text-success fw-bold my-3">
                        @Model.Gia.ToString("N0") VNĐ
                    </h3>

                    <hr />

                    <h5 class="fw-bold">Mô tả sách</h5>
                    <p class="text-muted" style="white-space: pre-line;">
                        @(string.IsNullOrWhiteSpace(Model.MoTa) ? "Chưa có mô tả cho sách này." : Model.MoTa)
                    </p>

                    <hr />

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        @if (Model.SoLuong > 0)
                        {
                            <div class="d-grid gap-3">
                                <form asp-controller="GioHang" asp-action="ThemVaoGio" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="sachId" value="@Model.Id" />

                                    <div class="row g-3 align-items-end">
                                        <div class="col-md-4">
                                            <label class="form-label fw-semibold">Số lượng</label>
                                            <input type="number"
                                                   name="soLuong"
                                                   value="1"
                                                   min="1"
                                                   max="@Model.SoLuong"
                                                   class="form-control" />
                                        </div>

                                        <div class="col-md-8 d-grid">
                                            <button type="submit" class="btn btn-success btn-lg">
                                                Thêm vào giỏ hàng
                                            </button>
                                        </div>
                                    </div>
                                </form>

                                <form asp-controller="DatHang" asp-action="MuaNgay" method="get">
                                    <input type="hidden" name="sachId" value="@Model.Id" />

                                    <div class="row g-3 align-items-end">
                                        <div class="col-md-4">
                                            <label class="form-label fw-semibold">Số lượng mua ngay</label>
                                            <input type="number"
                                                   name="soLuong"
                                                   value="1"
                                                   min="1"
                                                   max="@Model.SoLuong"
                                                   class="form-control" />
                                        </div>

                                        <div class="col-md-8 d-grid">
                                            <button type="submit" class="btn btn-warning btn-lg">
                                                Mua ngay
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-lg" disabled>
                                Sách đã hết hàng
                            </button>
                        }
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg">
                            Đăng nhập để mua hàng
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (sachLienQuan != null && sachLienQuan.Any())
    {
        <div class="mt-5">
            <h3 class="fw-bold mb-4">Sách liên quan</h3>

            <div class="row g-4">
                @foreach (var item in sachLienQuan)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6">
                        <div class="card h-100 shadow-sm border-0">
                            <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "/images/no-image.png" : item.HinhAnh)"
                                 class="card-img-top"
                                 style="height: 260px; object-fit: cover;"
                                 alt="@item.TenSach" />

                            <div class="card-body d-flex flex-column">
                                <h6 class="fw-bold">@item.TenSach</h6>
                                <p class="text-muted small mb-2">@item.TacGia</p>
                                <p class="text-success fw-bold">@item.Gia.ToString("N0") VNĐ</p>

                                <div class="mt-auto">
                                    <a asp-action="ChiTiet" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm w-100">
                                        Xem chi tiết
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>