    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@model IEnumerable<Book2.Models.Sach>

@{
    ViewData["Title"] = "Danh sách sách";
    var theLoais = ViewBag.TheLoais as List<Book2.Models.TheLoai>;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Danh sách sách</h2>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
            Về trang chủ
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index">
                <div class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label fw-semibold">Từ khóa</label>
                        <input type="text"
                               name="tuKhoa"
                               value="@ViewBag.TuKhoa"
                               class="form-control"
                               placeholder="Nhập tên sách hoặc tác giả..." />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Thể loại</label>
                        <select name="theLoaiId" class="form-select">
                            <option value="">-- Tất cả thể loại --</option>
                            @if (theLoais != null)
                            {
                                foreach (var item in theLoais)
                                {
                                    if (ViewBag.TheLoaiId != null && (int)ViewBag.TheLoaiId == item.Id)
                                    {
                                        <option value="@item.Id" selected>@item.TenTheLoai</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Id">@item.TenTheLoai</option>
                                    }
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-3 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-success w-100">
                            Tìm kiếm
                        </button>
                        <a asp-action="Index" class="btn btn-outline-dark w-100">
                            Làm mới
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "/images/no-image.png" : item.HinhAnh)"
                             class="card-img-top"
                             style="height: 320px; object-fit: cover;"
                             alt="@item.TenSach" />

                        <div class="card-body d-flex flex-column">
                            <span class="badge bg-light text-success border mb-2 align-self-start">
                                @(item.TheLoai?.TenTheLoai ?? "Chưa có thể loại")
                            </span>

                            <h5 class="card-title fw-bold" style="min-height: 48px;">
                                @item.TenSach
                            </h5>

                            <p class="text-muted mb-1">
                                <strong>Tác giả:</strong> @item.TacGia
                            </p>

                            <p class="text-muted mb-2">
                                <strong>Tồn kho:</strong> @item.SoLuong
                            </p>

                            <h5 class="text-success fw-bold mb-3">
                                @item.Gia.ToString("N0") VNĐ
                            </h5>

                            <div class="mt-auto d-grid gap-2">
                                <a asp-action="ChiTiet" asp-route-id="@item.Id" class="btn btn-outline-primary">
                                    Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Không tìm thấy sách phù hợp.
        </div>
    }
</div>