@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: calc(100vh - 200px); padding: 40px 0;">
    <div class="card border-0 shadow-lg" style="width: 100%; max-width: 450px; border-radius: 16px; overflow: hidden;">
        <div class="card-header bg-white border-0 text-center pt-4 pb-0">
            <h2 class="fw-bold" style="font-family: 'Merriweather', serif; color: var(--primary-color);">FrancisBooks</h2>
            <p class="text-muted mb-0">Chào mừng bạn quay lại</p>
        </div>
        <div class="card-body p-4 p-md-5">
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control rounded-pill px-4" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="px-4">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger ms-3"></span>
                </div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control rounded-pill px-4" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password" class="px-4">Mật khẩu</label>
                    <span asp-validation-for="Input.Password" class="text-danger ms-3"></span>
                </div>
                
                <div class="d-flex justify-content-between align-items-center mb-4 px-2">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" id="rememberMe" />
                        <label class="form-check-label text-muted" for="rememberMe">
                            Nhớ mật khẩu
                        </label>
                    </div>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none" style="font-weight: 500; font-size: 0.9rem;">Quên mật khẩu?</a>
                </div>
                
                <button id="login-submit" type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold text-white mb-4" style="border: none; font-size: 1.1rem;">
                    Đăng nhập
                </button>
                
                <div class="text-center text-muted">
                    Chưa có tài khoản? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none fw-bold">Đăng ký ngay</a>
                </div>
            </form>
            
            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <div class="text-center my-3">
                    <span class="text-muted" style="font-size: 0.85rem;">HOẶC ĐĂNG NHẬP BẰNG</span>
                </div>
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="d-flex justify-content-center gap-2">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="btn btn-outline-secondary rounded-circle" name="provider" value="@provider.Name" title="Đăng nhập bằng @provider.DisplayName" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;">
                            @if (provider.DisplayName == "Google") { <i class="bi bi-google"></i> }
                            else if (provider.DisplayName == "Facebook") { <i class="bi bi-facebook"></i> }
                            else { @provider.DisplayName }
                        </button>
                    }
                </form>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
